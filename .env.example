# Noetica Scientific Intelligence Engine
# Environment Variables Template

# 1. API Keys (Required)
# Used for personalized daily synthesis
GEMINI_API_KEY=your_gemini_api_key_here

# Used for email delivery (Required for SMTP)
NOETICA_EMAIL=your_sending_email@gmail.com
NOETICA_APP_PASSWORD=your_google_app_password

# 2. Database (Optional)
# If left blank, defaults to local SQLite (data/scientific_intelligence.db)
# DATABASE_URL=postgresql://user:password@localhost/noetica

# 3. Google Sheets Integration (Optional)
# If left blank, you can provide subscribers via NOETICA_SUBSCRIBERS
# GOOGLE_SHEET_ID=your_google_sheet_id
# NOETICA_SUBSCRIBERS=user1@example.com,user2@example.com

# 4. Feedback System (Optional)
# FEEDBACK_FORM_BASE_URL=https://docs.google.com/forms/d/e/...
# FEEDBACK_SHEET_ID=your_feedback_sheet_id
